generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  content   String
  type      PostType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PostType {
  POEM
  BLOG
  COLLECTION
}